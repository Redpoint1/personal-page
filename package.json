{
  "name": "personal-vue3",
  "version": "0.6.0",
  "private": true,
  "author": "Richard Rožár",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Redpoint1/personal-page.git"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/Redpoint1/personal-page/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "publish": "git push --tag && conventional-github-releaser -p custom && git push",
    "release": "standard-version",
    "sync": "rsync --chown www-data:www-data -av --progress ./dist/ root@remote.local:/var/www/html",
    "postinstall": "husky",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "^7.4.47",
    "vue": "^3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-angular": "^20.4.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-custom": "github:Redpoint1/conventional-changelog-custom#semver:^1.0.0",
    "conventional-github-releaser": "^3.1.5",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.5.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "sass-embedded": "^1.98.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  },
  "packageManager": "yarn@4.9.1",
  "commitlint": {
    "extends": [
      "@commitlint/config-angular"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "build",
          "breaking",
          "change",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "release",
          "revert",
          "style",
          "test"
        ]
      ]
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "standard-version": {
    "message": "release: %s",
    "preset": "custom"
  }
}
