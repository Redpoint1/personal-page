{
  "name": "personal-vue3",
  "version": "0.6.2",
  "private": true,
  "author": "Richard Rožár",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Redpoint1/personal-page.git"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/Redpoint1/personal-page/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "publish": "git push --tag && conventional-github-releaser -p custom && git push",
    "release": "commit-and-tag-version",
    "sync": "rsync --chown www-data:www-data -av --progress ./dist/ root@remote.local:/var/www/html",
    "postinstall": "husky",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "vue": "^3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "^5.0.3",
    "vuetify": "^3.12.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-angular": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@mdi/js": "^7.4.47",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "commit-and-tag-version": "^12.6.1",
    "commitizen": "^4.3.1",
    "conventional-github-releaser": "^3.1.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.1",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "bun@1.2.5",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
